# ── Variety Vibes Radio Hub — Environment Config ──
# Copy this file to .env and fill in your values

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Your Citrus3 live stream URL
STREAM_URL=https://hello.citrus3.com:2020/stream/varietyvibesradio

# Cloudflare R2 Storage (https://dash.cloudflare.com → R2)
# Account ID from R2 dashboard
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY
R2_SECRET_KEY=YOUR_R2_SECRET_KEY
R2_BUCKET=vv-radio-mp3s
# Optional: public bucket URL (if you enable public access on the bucket)
R2_PUBLIC_URL=https://pub-YOURHASH.r2.dev

# Server port (Railway sets this automatically)
PORT=3000
